---
import '../styles/global.css';
import { type Lang, ui } from '../lib/i18n';

interface Props {
	lang: Lang;
	title: string;
	description: string;
}

const { lang, title, description } = Astro.props;
const copy = ui[lang];
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="alternate" hreflang="en" href="/en/" />
		<link rel="alternate" hreflang="x-default" href="/en/" />
		<link rel="alternate" type="application/rss+xml" title={copy.siteTitle} href={`/${lang}/rss.xml`} />
	</head>
	<body>
		<header class="site-header">
			<div class="container topbar">
				<a class="brand" href={`/${lang}/`}>{copy.siteTitle}</a>
				<nav class="nav">
					<a href={`/${lang}/projects/`}>{copy.nav.projects}</a>
					<a href={`/${lang}/blog/`}>{copy.nav.blog}</a>
				</nav>
				<div class="actions">
					<button id="theme-toggle" type="button" aria-label={copy.toggleThemeAria}>🌙</button>
				</div>
			</div>
		</header>
		<main class="container main-content">
			<slot />
		</main>
		<footer class="site-footer">
			<div class="container">
				<p><a href="mailto:ozpinarcafer54@gmail.com">ozpinarcafer54@gmail.com</a></p>
				<p class="license-note">
					Unless otherwise stated, all content shared on this site is licensed under
					<a href="https://creativecommons.org/licenses/by-nc/4.0/" target="_blank" rel="noopener noreferrer">CC BY-NC 4.0</a>.
				</p>
			</div>
		</footer>
		<script is:inline>
			const root = document.documentElement;
			const themeKey = 'theme-preference';
			const storedTheme = localStorage.getItem(themeKey);
			const preferredTheme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
			const theme = storedTheme ?? preferredTheme;
			root.dataset.theme = theme;
			const button = document.getElementById('theme-toggle');
			const updateIcon = () => {
				if (!button) return;
				button.textContent = root.dataset.theme === 'dark' ? '☀️' : '🌙';
			};
			updateIcon();
			button?.addEventListener('click', () => {
				const nextTheme = root.dataset.theme === 'dark' ? 'light' : 'dark';
				root.dataset.theme = nextTheme;
				localStorage.setItem(themeKey, nextTheme);
				updateIcon();
			});
		</script>
	</body>
</html>
