---
import Layout from '../../layouts/Layout.astro';
import { isLang, SUPPORTED_LANGS, ui } from '../../lib/i18n';

export function getStaticPaths() {
	return SUPPORTED_LANGS.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang;
if (!isLang(lang)) return Astro.redirect('/en/');

const copy = ui[lang];
---

<Layout lang={lang} title={copy.siteTitle} description={copy.about.description}>
	<section class="hero">
		<h1>Welcome to my website</h1>
		<p class="muted">I'm a computer engineering student. Here's a little about me.</p>
	</section>

	<section class="section card">
		<p>
			I've been entangled with computers since before I could even walk — my dad likes to tell how,
			as a toddler who couldn't yet speak, I was already steering his game character around and
			walking it straight into the monsters to get it killed. For reasons like that, computer games
			and electronic devices have been part of my life for as long as I've been aware of myself.
		</p>
		<p>
			My real journey into coding and software development, though, goes back to the early years of
			high school — with love to my dear aunt, who encouraged me to attend a vocational high school.
		</p>
		<p>
			My core interest is robotics and embedded software. Even though I've worked on and gained
			experience across many other areas, this is without a doubt the field I enjoy the most and the
			one I want to keep working in.
		</p>
	</section>
</Layout>
