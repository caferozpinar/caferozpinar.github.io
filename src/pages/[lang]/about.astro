---
import Layout from '../../layouts/Layout.astro';
import { isLang, SUPPORTED_LANGS, ui } from '../../lib/i18n';

export function getStaticPaths() {
	return SUPPORTED_LANGS.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang;
if (!isLang(lang)) return Astro.redirect('/tr/');
const copy = ui[lang];
---

<Layout lang={lang} title={`${copy.about.title} | ${copy.siteTitle}`} description={copy.about.description}>
	<section class="hero">
		<h1>{copy.about.title}</h1>
		<p class="muted">{copy.about.description}</p>
	</section>

	<section class="section card">
		<h2>{lang === 'tr' ? 'Eğitim' : 'Education'}</h2>
		<p>
			{lang === 'tr'
				? 'Bilgisayar mühendisliği odağında eğitimimi sürdürürken yazılım, sistem ve düşük seviye konularda uygulamalı üretim yapıyorum.'
				: 'I am studying computer engineering while building practical work across software, systems, and low-level topics.'}
		</p>
	</section>

	<section class="section card">
		<h2>{lang === 'tr' ? 'İlgi Alanları' : 'Interests'}</h2>
		<p>
			{lang === 'tr'
				? 'Linux, tersine mühendislik, gömülü sistemler, ağ temelleri, performans analizi ve hata ayıklama süreçleri.'
				: 'Linux, reverse engineering, embedded systems, networking fundamentals, performance analysis, and debugging workflows.'}
		</p>
	</section>

	<section class="section card">
		<h2>{lang === 'tr' ? 'Yaklaşım' : 'Approach'}</h2>
		<p>
			{lang === 'tr'
				? 'Gösterişli anlatım yerine ölçülebilir teknik kararları, başarısız denemeleri ve çıkarımları paylaşırım.'
				: 'I prioritize measurable technical decisions, failed attempts, and practical takeaways over flashy presentation.'}
		</p>
	</section>
</Layout>
