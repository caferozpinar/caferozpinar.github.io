---
import Layout from '../../layouts/Layout.astro';
import { isLang, SUPPORTED_LANGS, ui } from '../../lib/i18n';

export function getStaticPaths() {
	return SUPPORTED_LANGS.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang;
if (!isLang(lang)) return Astro.redirect('/en/');
const copy = ui[lang];
---

<Layout lang={lang} title={`${copy.about.title} | ${copy.siteTitle}`} description={copy.about.description}>
	<section class="hero">
		<h1>{copy.about.title}</h1>
		<p class="muted">{copy.about.description}</p>
	</section>

	<section class="section card">
		<h2>Education</h2>
		<p>
			I am studying computer engineering while building practical work across software, systems, and low-level topics.
		</p>
	</section>

	<section class="section card">
		<h2>Interests</h2>
		<p>
			Linux, reverse engineering, embedded systems, networking fundamentals, performance analysis, and debugging workflows.
		</p>
	</section>

	<section class="section card">
		<h2>Approach</h2>
		<p>
			I prioritize measurable technical decisions, failed attempts, and practical takeaways over flashy presentation.
		</p>
	</section>
</Layout>
